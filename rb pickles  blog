      if (productGrid.scrollWidth > productGrid.clientWidth) {
        prevBtn.style.display = 'flex';
        nextBtn.style.display = 'flex';
        startAutoScroll();
      } else {
        prevBtn.style.display = 'none';
        nextBtn.style.display = 'none';
        stopAutoScroll();
      }
    }

    // === BLOG MODAL ===
    window.openBlogModal = function(id) {
        const article = blogArticles.find(a => a.id === id);
        if(!article) return;
        document.getElementById('modalImage').src = article.img;
        document.getElementById('modalTitle').innerText = article.title;
        document.getElementById('modalTag').innerText = article.tag;
        document.getElementById('modalAuthor').innerText = article.author;
        document.getElementById('modalDate').innerText = article.date;
        document.getElementById('modalContent').innerHTML = article.content;
        blogModal.classList.add('active');
        document.body.style.overflow = 'hidden';
    };
    
    window.closeBlogModal = function() { 
        blogModal.classList.remove('active'); 
        document.body.style.overflow = ''; 
    };
    
    blogModal.addEventListener('click', (e) => { 
        if (e.target === blogModal) closeBlogModal(); 
    });

    // === 3D TILT EFFECT ===
    function init3DTilt() {
      const cards = document.querySelectorAll('.product-card');
      cards.forEach(card => {
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          const centerX = rect.width / 2;
          const centerY = rect.height / 2;
          const rotateX = (y - centerY) / 20; 
          const rotateY = (centerX - x) / 20;
          card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
        });
        card.addEventListener('mouseleave', () => { 
          card.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale3d(1, 1, 1)'; 
        });
      });
    }

    // === CAROUSEL LOGIC ===
    function initCarouselControls() {
      productGrid.addEventListener('mouseenter', stopAutoScroll);
      productGrid.addEventListener('mouseleave', startAutoScroll);
      
      // Drag Start
      productGrid.addEventListener('mousedown', (e) => {
        stopAutoScroll();
        isDragging = true;
        productGrid.classList.add('cursor-grabbing');
        startX = e.pageX - productGrid.offsetLeft;
        scrollLeft = productGrid.scrollLeft;
      });
      
      // Drag End (Mouse Up)
      productGrid.addEventListener('mouseup', () => {
        isDragging = false;
        productGrid.classList.remove('cursor-grabbing');
        startAutoScroll(); // Resume auto-scroll after drag
      });
      
      // Drag End (Mouse Leave during drag)
      productGrid.addEventListener('mouseleave', () => {
        if (isDragging) {
            isDragging = false;
            productGrid.classList.remove('cursor-grabbing');
        }
      });
      
      // Drag Move
      productGrid.addEventListener('mousemove', (e) => {
        if (!isDragging) return;
        e.preventDefault();
        const x = e.pageX - productGrid.offsetLeft;
        const walk = (x - startX) * 2;
        productGrid.scrollLeft = scrollLeft - walk;
      });
      
      // Touch Events
      productGrid.addEventListener('touchstart', (e) => {
        stopAutoScroll();
        isDragging = true;
        startX = e.touches[0].pageX - productGrid.offsetLeft;
        scrollLeft = productGrid.scrollLeft;
      }, { passive: true });
      
      productGrid.addEventListener('touchend', () => {
        isDragging = false;
        startAutoScroll();
      });
      
      productGrid.addEventListener('touchmove', (e) => {
        if (!isDragging) return;
        const x = e.touches[0].pageX - productGrid.offsetLeft;
        const walk = (x - startX) * 2;
        productGrid.scrollLeft = scrollLeft - walk;
      }, { passive: true });

      // Navigation Buttons
      const scrollAmount = 320;
      prevBtn.addEventListener('click', () => { 
        stopAutoScroll(); 
        productGrid.scrollBy({ left: -scrollAmount, behavior: 'smooth' }); 
        setTimeout(startAutoScroll, 500);
      });
      
      nextBtn.addEventListener('click', () => { 
        stopAutoScroll(); 
        productGrid.scrollBy({ left: scrollAmount, behavior: 'smooth' }); 
        setTimeout(startAutoScroll, 500);
      });
    }

    function startAutoScroll() {
      stopAutoScroll();
      if (productGrid.scrollWidth <= productGrid.clientWidth) return;
      
      autoScrollTimeout = setTimeout(() => {
        const maxScroll = productGrid.scrollWidth - productGrid.clientWidth;
        const firstCard = productGrid.children[0];
        const cardWidth = firstCard ? firstCard.offsetWidth : 300;
        const gap = 32;
        const scrollDistance = cardWidth + gap;

        if (productGrid.scrollLeft >= maxScroll - 10) {
             productGrid.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
             productGrid.scrollBy({ left: scrollDistance, behavior: 'smooth' });
        }
        startAutoScroll();
      }, 5000);
    }

    function stopAutoScroll() { 
      clearTimeout(autoScrollTimeout); 
    }

    // === REVEAL ANIMATIONS ===
    function initRevealAnimations() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => { 
          if (entry.isIntersecting) entry.target.classList.add('active'); 
        });
      }, { threshold: 0.1, rootMargin: '0px' });
      
      document.querySelectorAll('.reveal-item').forEach(el => observer.observe(el));
    }

    // === UTILITIES ===
    window.orderOnWhatsApp = function(name) {
      const msg = encodeURIComponent(`Hi! I'd like to order: *${name}*. Please share availability.`);
      window.open(`https://wa.me/${waNumber}?text=${msg}`, '_blank');
    };
  </script>
